package java8practices.com;

interface Multiply {
    int multiply(int a,int b);
}
class Main2{
public static void main(String[] args) {
    Multiply m=new Multiply() {
        @Override
        public int multiply(int a, int b) {
            return a*b;
        }
    };
    System.out.println( m.multiply(2,4));
}
}
