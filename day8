package java8practices.com;
//using lambda expression which is maximum element
public interface Maximum {
    int max(int a,int b);
}
class Main3 {
    public static void main(String[] args) {
        Maximum m = (a, b) -> {
            if(a>b)
                return a;
            else
                return b;
            };
            System.out.println(m.max(3, 4));

    }
}
------------output---------------
  4
