package java8practices.com;

public interface Addition {
    void addition(int a,int b);
}
class Main1{
    public static void main(String[] args) {
        Addition add=new Addition() {
            @Override
            public void addition(int a, int b) {
                System.out.println((a+b));
            }
        };
        add.addition(2,5);
    }
}
