//The below is the ConstructorReference
interface BookFactory{
    Book create();
}
class Book{
    public Book(){
        System.out.println("Book Created");
    }
}
class Main13{
    public static void main(String[] args) {
        BookFactory bookFactory=Book::new;
        Book book=bookFactory.create();
    }
}
